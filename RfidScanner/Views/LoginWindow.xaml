<Window x:Class="RfidScanner.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:viewmodels="clr-namespace:RfidScanner.ViewModels"
        Title="Acuris - Login"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Icon="pack://application:,,,/Assets/AppIcon.png"
        Background="{StaticResource BgDarkBrush}"
        Foreground="{StaticResource TextPrimaryBrush}"
        Height="520" Width="480">

    <Window.DataContext>
        <viewmodels:LoginViewModel/>
    </Window.DataContext>

    <Border HorizontalAlignment="Center" VerticalAlignment="Center" Background="{StaticResource BgCardBrush}" CornerRadius="10" Padding="30" Width="400">
        <Border.Effect>
            <DropShadowEffect Color="#000000" Opacity="0.1" BlurRadius="20" ShadowDepth="5" Direction="270"/>
        </Border.Effect>
        <StackPanel>
            <Image Source="pack://application:,,,/Assets/AppLogo.png" Height="50" HorizontalAlignment="Center" Margin="0,0,0,10"/>
            
            <TextBlock Text="Log In" FontSize="24" FontWeight="Bold" Foreground="#0033CC" HorizontalAlignment="Center" Margin="0,10,0,5"/>
            <TextBlock Text="Welcome back! Please log in to continue." FontSize="14" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,30"/>

            <TextBlock Text="Email" Margin="0,0,0,5" FontWeight="SemiBold"/>
            <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" Padding="8" Background="{StaticResource BgCardBrush}" Foreground="{StaticResource TextPrimaryBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Margin="0,0,0,15"/>

            <TextBlock Text="Password" Margin="0,0,0,5" FontWeight="SemiBold"/>
            <PasswordBox x:Name="TxtPassword" PasswordChanged="TxtPassword_PasswordChanged" Padding="8" Background="{StaticResource BgCardBrush}" Foreground="{StaticResource TextPrimaryBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Margin="0,0,0,5"/>

            <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource DangerBrush}" TextWrapping="Wrap" Margin="0,5,0,15" Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}"/>

            <Button Content="Log In" Command="{Binding LoginCommand}" CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}" 
                    Background="{StaticResource AccentBrush}" Foreground="White" FontWeight="Bold" Height="40" Margin="0,10,0,0">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>
    </Border>
</Window>
