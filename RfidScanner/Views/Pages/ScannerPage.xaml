<UserControl x:Class="RfidScanner.Views.Pages.ScannerPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:RfidScanner.Converters">

    <UserControl.Resources>
        <conv:RssiToColorConverter x:Key="RssiToColor"/>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis"/>

        <Style x:Key="DeviceListItemButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="10,8">
                            <ContentPresenter HorizontalAlignment="Stretch"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#E8F4FD"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#D6EBFA"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource BgPanelBrush}"
                CornerRadius="10"
                Padding="16,12"
                Margin="0,0,0,12">
            <TextBlock Text="{Binding StatusMessage}"
                       FontSize="13"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       TextWrapping="Wrap"/>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- BLE device panel -->
            <Border Background="{StaticResource BgPanelBrush}"
                    CornerRadius="10" Padding="14"
                    Margin="0,0,8,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="Bluetooth Devices"
                               FontSize="15" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               Margin="0,0,0,10"/>

                    <Button Grid.Row="1"
                            Command="{Binding ScanDevicesCommand}"
                            Margin="0,0,0,10">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
                                <Setter Property="Content" Value="Scan Devices"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsScanning}" Value="True">
                                        <Setter Property="Content" Value="Stop Scan"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <TextBlock Grid.Row="2"
                               Text="{Binding DeviceListStatus}"
                               FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,0,0,8"
                               TextWrapping="Wrap"/>

                    <Border Grid.Row="3"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Margin="0,0,0,10">
                        <ListBox ItemsSource="{Binding Devices}"
                                 SelectedItem="{Binding SelectedDevice}"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 Height="220">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin" Value="0,0,0,4"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <ContentPresenter/>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource DeviceListItemButton}"
                                            Margin="0"
                                            Command="{Binding DataContext.ConnectToDeviceCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="4"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0"
                                                    CornerRadius="2"
                                                    Margin="0,2,8,2">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="{StaticResource BorderBrush}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsChainway}" Value="True">
                                                                <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                            </Border>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="{Binding DeviceLabel}"
                                                           FontWeight="SemiBold"
                                                           FontSize="13"
                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock FontSize="11"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           Margin="0,2,0,0"
                                                           TextTrimming="CharacterEllipsis"
                                                           Text="{Binding Mac}"/>
                                            </StackPanel>
                                        </Grid>
                                    </Button>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>

                    <Border Grid.Row="4"
                            Background="#E8F5E9"
                            BorderBrush="{StaticResource SuccessBrush}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="10,8"
                            Margin="0,0,0,10"
                            Visibility="{Binding IsConnected, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="{Binding ConnectedDeviceText}"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   TextWrapping="Wrap"/>
                    </Border>

                    <StackPanel Grid.Row="5">
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Tx Power:" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,10,0"/>
                            <Slider Grid.Column="1" Minimum="5" Maximum="30" Value="{Binding TransmitPower}" VerticalAlignment="Center" IsSnapToTickEnabled="True" TickFrequency="1"/>
                            <TextBlock Grid.Column="2" Text="{Binding TransmitPower, StringFormat='{}{0} dBm'}" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" Margin="6,0,6,0" FontSize="12" Width="45"/>
                            <Button Grid.Column="3" Content="Set" Padding="8,2" Command="{Binding ApplyPowerCommand}" Style="{StaticResource SecondaryButton}"/>
                        </Grid>

                        <Button Command="{Binding ToggleSoundCommand}" Margin="0,0,0,6">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource WarningButton}">
                                    <Setter Property="Content" Value="Unmute Beep"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSoundMuted}" Value="False">
                                            <Setter Property="Content" Value="Mute Beep"/>
                                            <Setter Property="Background" Value="{StaticResource BgCardBrush}"/>
                                            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                            <Setter Property="BorderThickness" Value="1"/>
                                            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button Content="Disconnect"
                                Style="{StaticResource DangerButton}"
                                Command="{Binding DisconnectCommand}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- RFIDStockPro-style tag panel -->
            <Border Grid.Column="1"
                    Background="{StaticResource BgPanelBrush}"
                    CornerRadius="10"
                    Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Connection status -->
                    <Border Grid.Row="0" Padding="16,12" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                        <Grid>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Ellipse Width="10" Height="10" Margin="0,0,8,0">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Fill" Value="#9CA3AF"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                                    <Setter Property="Fill" Value="{StaticResource SuccessBrush}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsInventoryRunning}" Value="True">
                                                    <Setter Property="Fill" Value="{StaticResource AccentBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                                <TextBlock Text="{Binding ConnectionStatusText}"
                                           FontSize="14" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center"
                                        Visibility="{Binding IsInventoryRunning, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="Time: " FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                                <TextBlock Text="{Binding ScanDurationDisplay}" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Stats header -->
                    <Border Grid.Row="1" Padding="16,14" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                        <Grid VerticalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="1"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="1" HorizontalAlignment="Center" MinWidth="120">
                                <TextBlock Text="Unique Tags"
                                           FontSize="13" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding UniqueTagCount}"
                                           FontSize="24" FontWeight="Bold"
                                           Foreground="{StaticResource AccentBrush}"
                                           HorizontalAlignment="Center"
                                           Margin="0,4,0,0"/>
                            </StackPanel>

                            <Border Grid.Column="2"
                                    Background="{StaticResource BorderBrush}"
                                    Width="1"
                                    Margin="28,2"
                                    VerticalAlignment="Stretch"/>

                            <StackPanel Grid.Column="3" HorizontalAlignment="Center" MinWidth="120">
                                <TextBlock Text="Scanned Count"
                                           FontSize="13" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding TotalReadCount}"
                                           FontSize="24" FontWeight="Bold"
                                           Foreground="{StaticResource AccentBrush}"
                                           HorizontalAlignment="Center"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Tag table -->
                    <Grid Grid.Row="2" Margin="8,8,8,0">
                        <DataGrid ItemsSource="{Binding LiveTagsView}"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  CanUserResizeColumns="True"
                                  CanUserSortColumns="True"
                                  AutoGenerateColumns="False"
                                  MinHeight="120">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Tag"
                                                    Binding="{Binding TidDisplay}"
                                                    Width="*"
                                                    MinWidth="180"/>
                                <DataGridTextColumn Header="Count"
                                                    Binding="{Binding ReadCount}"
                                                    Width="80"/>
                                <DataGridTemplateColumn Header="RSSI" Width="100">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <Ellipse Width="8" Height="8" Margin="0,0,6,0"
                                                         Fill="{Binding Rssi, Converter={StaticResource RssiToColor}}"/>
                                                <TextBlock Text="{Binding RssiDisplay}" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                        <!-- Empty placeholder -->
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                    Margin="24"
                                    Visibility="{Binding ShowTagPlaceholder, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="📡"
                                       FontSize="42"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,12"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock Text="Press Start Scan or device trigger to begin scanning RFID tags"
                                       FontSize="14"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap"
                                       MaxWidth="320"/>
                        </StackPanel>

                        <!-- Scanning progress -->
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                    Visibility="{Binding ShowScanProgress, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="Scanning..."
                                       FontSize="16" FontWeight="SemiBold"
                                       Foreground="{StaticResource AccentBrush}"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="Hold reader near tags"
                                       FontSize="13"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center"
                                       Margin="0,8,0,0"/>
                        </StackPanel>
                    </Grid>

                    <!-- Start / Stop -->
                    <Grid Grid.Row="3" Margin="12,8,12,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0"
                                Content="Start Scan"
                                Style="{StaticResource PrimaryButton}"
                                Command="{Binding StartInventoryCommand}"
                                Padding="14,12"
                                FontSize="14" FontWeight="SemiBold"/>
                        <Button Grid.Column="2"
                                Content="Stop Scan"
                                Style="{StaticResource DangerButton}"
                                Command="{Binding StopInventoryCommand}"
                                Padding="14,12"
                                FontSize="14" FontWeight="SemiBold"/>
                    </Grid>

                    <!-- Clear / Export -->
                    <Grid Grid.Row="4" Margin="12,0,12,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0"
                                Content="Clear"
                                Style="{StaticResource SecondaryButton}"
                                Command="{Binding ClearLiveTagsCommand}"
                                Padding="14,10"
                                FontSize="14" FontWeight="SemiBold"/>
                        <Button Grid.Column="2"
                                Content="Export CSV / Excel"
                                Style="{StaticResource PrimaryButton}"
                                Command="{Binding ExportCsvCommand}"
                                Padding="14,10"
                                FontSize="14" FontWeight="SemiBold"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <TextBlock Grid.Row="2"
                   Text="Scan Devices, then tap your R6 in the list to connect directly — do not pair in Windows Bluetooth settings."
                   Foreground="{StaticResource TextSecondaryBrush}"
                   FontSize="11"
                   Margin="0,10,0,0"
                   TextWrapping="Wrap"
                   HorizontalAlignment="Center"/>
    </Grid>
</UserControl>
