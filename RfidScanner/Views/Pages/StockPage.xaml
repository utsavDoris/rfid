<UserControl x:Class="RfidScanner.Views.Pages.StockPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource BgPanelBrush}" CornerRadius="10" Padding="16,12" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Product Stock" FontSize="18" FontWeight="Bold" Foreground="{StaticResource AccentBrush}"/>
                    <TextBlock Text="{Binding StatusMessage}" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                </StackPanel>
                <Button Grid.Column="1" Content="Refresh" Style="{StaticResource PrimaryButton}" Command="{Binding RefreshCommand}" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <Border Grid.Row="1" Background="{StaticResource BgPanelBrush}" CornerRadius="10" Padding="14,10" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Search:" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,10,0"/>
                <TextBox Grid.Column="1"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Padding="6,4"
                         Background="{StaticResource BgCardBrush}"
                         Foreground="{StaticResource TextPrimaryBrush}"
                         BorderBrush="{StaticResource BgDarkBrush}"
                         BorderThickness="1"
                         ToolTip="Search by SKU, name, tag ID, or style"/>
            </Grid>
        </Border>

        <Border Grid.Row="2" Background="{StaticResource BgPanelBrush}" CornerRadius="10" Padding="14">
            <DataGrid ItemsSource="{Binding ProductsView}" IsReadOnly="True" AutoGenerateColumns="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="SKU" Binding="{Binding Sku}" Width="100"/>
                    <DataGridTextColumn Header="Product" Binding="{Binding ProductName}" Width="*"/>
                    <DataGridTextColumn Header="Style" Binding="{Binding StyleNo}" Width="90"/>
                    <DataGridTextColumn Header="Tag ID" Binding="{Binding TagId}" Width="120"/>
                    <DataGridTextColumn Header="Stock" Binding="{Binding StockStatusDisplay}" Width="90"/>
                    <DataGridTextColumn Header="Price" Binding="{Binding Price}" Width="80"/>
                    <DataGridTextColumn Header="Location" Binding="{Binding Location}" Width="90"/>
                    <DataGridTextColumn Header="Label" Binding="{Binding Label}" Width="80"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
