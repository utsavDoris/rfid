<Window x:Class="RfidScanner.Views.ProfileWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:viewmodels="clr-namespace:RfidScanner.ViewModels"
        Title="Acuris - My Profile" Height="350" Width="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BgDarkBrush}"
        Foreground="{StaticResource TextPrimaryBrush}"
        Icon="pack://application:,,,/Assets/AppIcon.png">

    <Window.DataContext>
        <viewmodels:ProfileViewModel/>
    </Window.DataContext>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="My Profile" FontSize="24" FontWeight="Bold" Foreground="{StaticResource AccentBrush}" Margin="0,0,0,20"/>

        <TextBlock Grid.Row="1" Text="Name" Margin="0,0,0,5" FontWeight="SemiBold"/>
        <TextBox Grid.Row="2" Text="{Binding UserName, UpdateSourceTrigger=PropertyChanged}" Padding="8" Background="{StaticResource BgCardBrush}" Foreground="{StaticResource TextPrimaryBrush}" BorderBrush="{StaticResource BgDarkBrush}" Margin="0,0,0,15"/>

        <TextBlock Grid.Row="3" Text="Email" Margin="0,0,0,5" FontWeight="SemiBold"/>
        <TextBlock Grid.Row="4" Text="{Binding Email}" Padding="8" Background="{StaticResource BgPanelBrush}" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,15"/>

        <StackPanel Grid.Row="5" Orientation="Horizontal" Margin="0,0,0,20">
            <TextBlock Text="Company:" FontWeight="SemiBold" Margin="0,0,5,0"/>
            <TextBlock Text="{Binding CompanyName}" Margin="0,0,20,0"/>
            <TextBlock Text="Role:" FontWeight="SemiBold" Margin="0,0,5,0"/>
            <TextBlock Text="{Binding RoleName}" FontWeight="Bold">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding RoleName}" Value="Owner">
                                <Setter Property="Foreground" Value="#FFC107"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding RoleName}" Value="Manager">
                                <Setter Property="Foreground" Value="#2196F3"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding RoleName}" Value="Staff">
                                <Setter Property="Foreground" Value="#4CAF50"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </StackPanel>

        <TextBlock Grid.Row="6" Text="{Binding StatusMessage}" Foreground="{StaticResource SuccessBrush}" TextWrapping="Wrap" Margin="0,5,0,15"/>

        <Button Grid.Row="7" Content="Save Profile" Command="{Binding SaveProfileCommand}" CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}" 
                Background="{StaticResource AccentBrush}" Foreground="White" FontWeight="Bold" Height="40" VerticalAlignment="Top">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" CornerRadius="6">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Button.Template>
        </Button>
    </Grid>
</Window>
