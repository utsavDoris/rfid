<Window x:Class="RfidScanner.Views.ShellWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:RfidScanner.ViewModels"
        xmlns:pages="clr-namespace:RfidScanner.Views.Pages"
        Title="Acuris - Desktop"
        Height="720" Width="1200"
        MinHeight="600" MinWidth="1000"
        Background="{StaticResource BgDarkBrush}"
        Icon="pack://application:,,,/Assets/AppIcon.png"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
            <pages:DashboardPage/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:MainViewModel}">
            <pages:ScannerPage/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:StockViewModel}">
            <pages:StockPage/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ModulePlaceholderViewModel}">
            <pages:ModulePlaceholderPage/>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Background="{StaticResource BgPanelBrush}" Padding="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="8,8,8,16">
                    <TextBlock Text="Acuris"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="{StaticResource AccentBrush}"/>
                    <TextBlock Text="Desktop"
                               FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                </StackPanel>

                    <ListBox x:Name="NavList"
                             Grid.Row="1"
                             ItemsSource="{Binding NavItems}"
                             SelectedValue="{Binding SelectedNavId}"
                             SelectedValuePath="Id"
                             SelectionChanged="NavList_OnSelectionChanged"
                             BorderThickness="0"
                             Background="Transparent">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="10,8"/>
                            <Setter Property="Margin" Value="0,2"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="Bd" Background="Transparent" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource BgCardBrush}"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource BgCardBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock Text="{Binding Title}" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                <TextBlock Text="{Binding Description}" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,2,0,0"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <TextBlock Grid.Row="2"
                           Text="FEATURE_PLAN.md"
                           FontSize="10"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="8"
                           TextWrapping="Wrap"/>
            </Grid>
        </Border>

        <!-- Main area -->
        <Grid Grid.Column="1" Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{StaticResource BgPanelBrush}"
                    CornerRadius="10"
                    Padding="16,12"
                    Margin="0,0,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="{Binding PageTitle}"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               VerticalAlignment="Center"/>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="{Binding CurrentUserEmail}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,12,0"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <Button Content="Profile"
                                Command="{Binding OpenProfileCommand}"
                                CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                                Padding="12,6"
                                Background="{StaticResource BgCardBrush}"
                                Foreground="{StaticResource TextPrimaryBrush}"
                                Margin="0,0,8,0"/>
                        <Button Content="Users"
                                Command="{Binding OpenUserAdminCommand}"
                                CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                                Padding="12,6"
                                Background="{StaticResource BgCardBrush}"
                                Foreground="{StaticResource TextPrimaryBrush}"
                                Margin="0,0,8,0"/>
                        <Button Content="Logout"
                                Command="{Binding LogoutCommand}"
                                CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                                Padding="12,6"
                                Background="{StaticResource BgCardBrush}"
                                Foreground="{StaticResource TextPrimaryBrush}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <ContentControl Grid.Row="1"
                            Content="{Binding CurrentPage}"/>
        </Grid>
    </Grid>
</Window>
